# ============================================================
# BFSI Intent Firewall - Environment Variables
# Copy to .env and fill in your values
# ============================================================

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-opus-4-8

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Redis
REDIS_URL=redis://redis:6379

# PostgreSQL (shared by all services)
POSTGRES_DB=intent_firewall
POSTGRES_USER=bfsi
POSTGRES_PASSWORD=bfsi_secret_2024
DATABASE_URL=postgresql+asyncpg://bfsi:bfsi_secret_2024@postgres:5432/intent_firewall

# SMTP Email (use Gmail App Password or corporate SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=alerts@yourbank.com
SMTP_PASSWORD=your_smtp_app_password

# Stakeholder Email Routing
FRAUD_TEAM_EMAILS=fraud-ops@yourbank.com,security@yourbank.com
LOAN_OPS_EMAILS=loan-operations@yourbank.com
BRANCH_MANAGER_EMAIL=branch.manager@yourbank.com
COMPLIANCE_EMAIL=compliance@yourbank.com

# App Settings
APP_DEBUG=false
APP_PORT=8000
